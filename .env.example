# Agent-Native Tweet Lab
TWEET_LAB_API=http://127.0.0.1:4173
TWEET_LAB_X_HANDLE=example
HOST=127.0.0.1
PORT=4188

# Persistent SQL (optional; local development defaults to SQLite under data/)
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token

# Agent Native model providers (optional; not required for Hermes-backed Tweet Lab generation)
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# Notion OAuth for inherited Content features (optional)
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=

# Production access control (optional; follow Agent Native deployment docs)
# ACCESS_TOKEN=
