# Core server
HOST=127.0.0.1
PORT=4173
NODE_ENV=production
TWEET_LAB_DATA_DIR=/absolute/path/to/private/tweet-lab-data
TWEET_LAB_PUBLIC_HOST=

# Hermes generation adapter (default mode)
GORO_HERMES_PROFILE=goro
HERMES_BIN=hermes
GORO_HERMES_TIMEOUT_MS=60000
# GORO_GENERATE_MODE=mock
# GORO_GENERATE_URL=https://your-private-generation-endpoint.example/generate

# Optional grounding files
TWEET_LAB_VOICE_DNA_PATH=/absolute/path/to/voice-dna.md
TWEET_LAB_CONTEXT_DIR=/absolute/path/to/context-notes
# Linux/macOS: separate multiple files with a colon. Windows uses a semicolon.
TWEET_LAB_COMPANY_CONTEXT_FILES=/absolute/path/to/company.md

# Optional read-only X integration
TWEET_LAB_X_HANDLE=example
X_BEARER_TOKEN=
X_USER_ACCESS_TOKEN=

# Optional Postiz scheduling integration
POSTIZ_API_URL=https://postiz.com/api
POSTIZ_API_KEY=
POSTIZ_X_INTEGRATION_ID=
